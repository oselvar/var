---
import DocsLayout from '../../layouts/DocsLayout.astro'
import { loadDocEntries } from '../../lib/docs-collection'
import { buildNav } from '../../lib/docs-nav'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const entries = await loadDocEntries()
const groups = buildNav(entries, base, null)
---

<DocsLayout
  title="Docs"
  description="Vár documentation: tutorials, how-to guides, reference, and explanation."
  base={base}
  groups={groups}
  breadcrumb={null}
>
  <h1>Docs</h1>
  <p class="lede">
    Vár is executable documentation. Run the docs against your system; if behaviour drifts,
    you get an error. Organised with <a href="https://diataxis.fr/">Diátaxis</a>.
  </p>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-5 my-10">
    {groups.map((group) => (
      <section class="border border-line-subtle rounded-none p-6">
        <p class="uppercase text-sm tracking-[0.04em] text-subtle m-0">{group.area.diataxis}</p>
        <h2 class="font-sans font-semibold text-xl mt-1 mb-3">{group.area.label}</h2>
        {group.links.length > 0 ? (
          <ul class="list-none p-0 m-0">
            {group.links.map((link) => (
              <li class="my-1.5"><a href={link.href}>{link.title}</a></li>
            ))}
          </ul>
        ) : (
          <p class="text-[14px] opacity-60 m-0">Coming soon — spec syntax, step matching, CLI flags.</p>
        )}
      </section>
    ))}
  </div>
</DocsLayout>
