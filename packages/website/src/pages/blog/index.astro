---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<Base title="Vár blog" description="Notes on Behaviour-Driven Development, executable specs, and Vár.">
  <main class="page">
    <nav class="doc-nav" aria-label="Breadcrumb">
      <a href={`${base}/`}>Vár</a>
      <span aria-hidden="true">›</span>
      <span>blog</span>
    </nav>

    <h1>blog</h1>
    <p class="lede">
      Notes on specs, examples, and not making people cry.
      <a href={`${base}/rss.xml`}>RSS</a>.
    </p>

    <ul class="list-none p-0 my-8">
      {posts.map((p) => (
        <li class="py-4 border-b border-line-subtle">
          <a class="font-sans font-semibold text-2xl text-ink no-underline hover:text-accent" href={`${base}/blog/${p.id}/`}>{p.data.title}</a>
          <time class="block text-[13px] text-muted my-1" datetime={fmt(p.data.pubDate)}>{fmt(p.data.pubDate)}</time>
          <p class="mt-1.5 mb-0">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </main>
</Base>
