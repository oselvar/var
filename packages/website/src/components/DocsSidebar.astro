---
import type { NavGroup } from '../lib/docs-nav'

interface Props {
  groups: ReadonlyArray<NavGroup>
}
const { groups } = Astro.props
---

<nav aria-label="Docs sections">
  {groups.map((group) => (
    <section class="mb-6">
      <p class="text-sm font-semibold text-subtle uppercase tracking-[0.04em] mb-2">
        {group.area.label}
        <span class="block normal-case tracking-normal text-sm opacity-70">{group.area.diataxis}</span>
      </p>
      {group.links.length > 0 ? (
        <ul class="list-none p-0 m-0">
          {group.links.map((link) => (
            <li class="my-0.5">
              <a
                href={link.href}
                class={`block px-2 py-1 text-ink no-underline rounded-none hover:bg-raised${link.current ? ' is-current bg-raised text-accent font-semibold shadow-[inset_2px_0_0_var(--accent)]' : ''}`}
                aria-current={link.current ? 'page' : undefined}
              >{link.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="m-0 px-2 py-1 text-subtle">Coming soon</p>
      )}
    </section>
  ))}
</nav>
