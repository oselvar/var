{
  "name": "@oselvar/cucumber",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=\"--import tsx\" cucumber-js && pnpm test:bdd && pnpm test:bdd-vitest",
    "test:cucumber": "NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "test:bdd": "NODE_OPTIONS=\"--import tsx\" node ../bdd-cli/src/bin.ts run",
    "test:bdd-vitest": "NODE_OPTIONS=\"--import tsx\" vitest run"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@oselvar/var": "workspace:*",
    "@oselvar/var-cli": "workspace:*",
    "@oselvar/var-vitest": "workspace:*",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
